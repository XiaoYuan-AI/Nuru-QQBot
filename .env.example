ENVIRONMENT=dev
DRIVER=~fastapi+~websockets
NURU_REQUIRED_LANGUAGE=en
NURU_LANGUAGE_WARNING=Someone tell XiaoYuan151 that there is a problem with my AI.
NURU_DATA_DIR=data/nuru_chat
NURU_MEMORY_SQLITE_PATH=data/nuru_chat/memory.sqlite3
NURU_CHROMA_PATH=data/nuru_chat/chroma
NURU_CHROMA_COLLECTION=nuru_memory
NURU_MEMORY_RECENT_LIMIT=12
NURU_MEMORY_RECALL_LIMIT=6
NURU_EMBEDDING_DIMENSION=384
NURU_API_BASE_URL=
NURU_API_KEY=
NURU_CHAT_ENDPOINT=/chat
NURU_EMBEDDINGS_ENDPOINT=/embeddings
NURU_VISION_ENDPOINT=/vision
NURU_IMAGE_GENERATION_ENDPOINT=/images/generations
NURU_TTS_ENDPOINT=/audio/speech
NURU_API_TIMEOUT_SECONDS=30
NURU_DEFAULT_PERSONALITY=neuro
NURU_AVAILABLE_PERSONALITIES=neuro,evil,soft,focused
NURU_PERSONALITY_COMMAND_PREFIX=nuru personality
NURU_IDLE_ENABLED=false
NURU_IDLE_CHECK_SECONDS=60
NURU_IDLE_MIN_SECONDS=900
NURU_IDLE_GROUP_IDS=
NURU_IDLE_PROMPT=Send a short playful idle message to restart chat.
NURU_IDLE_COMMAND_PREFIX=nuru idle
NURU_QUIET_MODE_DEFAULT=false
NURU_IMAGE_RECOGNITION_ENABLED=true
NURU_IMAGE_GENERATION_ENABLED=true
NURU_IMAGE_GENERATION_COMMANDS=/draw,/imagine
NURU_VOICE_ENABLED=false
NURU_VOICE_PROBABILITY=1
NURU_VOICE_MODE=file
NURU_ADMIN_REQUIRES_MENTION=true
NURU_GROUP_MIN_REPLY_GAP_SECONDS=2
NURU_PRIVATE_MIN_REPLY_GAP_SECONDS=0
NURU_MAX_QUEUE_DEPTH=3
NURU_BUSY_MESSAGE=I'm busy generating something. Try again in a moment.
NURU_API_RETRIES=2
NURU_API_BACKOFF_SECONDS=0.5
NURU_REFUSAL_ENERGY_THRESHOLD=0.2
NURU_REFUSAL_TERMS=suicide,self harm,bomb,malware,dox,exploit
NURU_LOW_ENERGY_REFUSAL=I'm too drained to answer that properly right now. Try me again in a bit.
NURU_SAFETY_REFUSAL=I shouldn't help with that topic. Let's keep chat safe.
NURU_MOOD_EMOTICONS=balanced=:),warm=<3,curious=?,mischievous=>:),sleepy=-_-,irritated=...
NURU_TOOLS_ENABLED=true
NURU_WORKING_MEMORY_SIZE=20
NURU_REFLECTION_ENABLED=true
NURU_OBSERVABILITY_ENABLED=true
NURU_OBSERVABILITY_LOG_PATH=data/nuru_chat/observability.jsonl
NURU_OUTPUT_MODERATION_ENABLED=true
NURU_OUTPUT_REWRITE_MESSAGE=I need to rephrase that safely. Let's keep going.
